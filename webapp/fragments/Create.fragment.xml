<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Dialog
        id="CreateDialog"
        title="Select"
    >
        <content>
            <VBox
                id="tablePostingVBox"
                class="sapUiMediumMargin"
            >
                <!-- Selected Table Info -->
                <MessageStrip
                    id="selectedTableInfo"
                    text="Select Payment way "
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom"
                />
                <ComboBox id="_IDGenComboBox1" selectedKey="{/selectedView}" placeholder="Not Selected">
                    <items>
                        <core:Item id="_IDGenItem1" key="v1" text="Post Outgoing Payment"/>
                        <core:Item id="_IDGenItem3" key="v2" text="Down Payment"/>
                        <core:Item id="_IDGenItem4" key="v3" text="On Account Payment"/>
                    </items>
                </ComboBox>
            </VBox>
        </content>

        <buttons>
           <Button
                id="executeTablePostingBtn"
                text="Go"
                type="Emphasized"
                press=".onGoCreate"
            />
            <Button
                id="cancelTablePostingBtn"
                text="Cancel"
                press="onCloseCreateDialog"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
