<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="supplierVHOA"
        title="Select Supplier"
        search=".InputHelpsOA.onSearchSupplier"
        confirm=".InputHelpsOA.onConfirmSupplier"
        cancel=".InputHelpsOA.onCloseSupplierDialog"
        items="{
            path: '/suppVH',
            sorter: { path: 'Supplier' }
        }">
        <StandardListItem id="_IDGenStandardListItemsOA"
            title="{Supplier}"
            description="{SupplierName}"
            type="Active"/>
    </SelectDialog>
    
</core:FragmentDefinition>