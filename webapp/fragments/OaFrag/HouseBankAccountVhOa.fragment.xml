<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="houseBankAccountVHOA"
        title="Select House Bank Account"
        search=".InputHelpsOA.onSearchHouseBankAccount"
        confirm=".InputHelpsOA.onConfirmHouseBankAccount"
        cancel=".InputHelpsOA.onCloseHouseBankAccountDialog"
        items="{/I_HouseBankAccountVH}">
        <StandardListItem id="_IDGenStandardListItem3OA"
            title="{HouseBankAccount}"
            description="{HouseBankAccountDescription}"
            info="{BankAccount}"
            type="Active"/>
    </SelectDialog>
    
</core:FragmentDefinition>