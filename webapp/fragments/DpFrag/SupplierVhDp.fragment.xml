<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="supplierVHdp"
        title="Select Supplier"
        search=".InputHelpsDP.onSearchSupplier"
        confirm=".InputHelpsDP.onConfirmSupplier"
        cancel=".InputHelpsDP.onCloseSupplierDialog"
        items="{
            path: '/suppVH',
            sorter: { path: 'Supplier' }
        }">
        <StandardListItem id="_IDGenStandardListItemdp"
            title="{Supplier}"
            description="{SupplierName}"
            type="Active"/>
    </SelectDialog>
    
</core:FragmentDefinition>