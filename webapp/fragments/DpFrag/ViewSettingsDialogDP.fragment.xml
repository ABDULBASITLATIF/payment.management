<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="filterSortDialogdp" title="View Settings" contentWidth="40rem">
        <content>
            <IconTabBar id="viewSettingsTabBardp" expanded="true" headerMode="Inline">
                <items>
                    <IconTabFilter id="_IDGenIconTabFilterdp" text="Sort" key="sort">
                        <VBox id="_IDGenVBox1dp" class="sapUiSmallMargin">
                            <Label id="_IDGenLabeldp" text="Sort By"/>
                            <Select id="sortFieldSelectdp">
                                <items>
                                    <core:Item id="_IDGenItem" key=""         text="None"/>
                                    <core:Item id="_IDGenItem29" key="docNo"    text="Document Number"/>
                                    <core:Item id="_IDGenItem30" key="year1"    text="Fiscal Year"/>
                                    <core:Item id="_IDGenItem31" key="lineItem" text="Line Item"/>
                                    <core:Item id="_IDGenItem32" key="vendor"   text="Supplier"/>
                                    <core:Item id="_IDGenItem33" key="amntLC"   text="Amount (Local)"/>
                                    <core:Item id="_IDGenItem34" key="amntDC"   text="Amount (Doc)"/>
                                    <core:Item id="_IDGenItem35" key="curr"     text="Currency"/>
                                    <core:Item id="_IDGenItem36" key="refNo"    text="Reference"/>
                                    <core:Item id="_IDGenItem37" key="assignNo" text="Assignment"/>
                                    <core:Item id="_IDGenItem38" key="compCode" text="Company Code"/>
                                </items>
                            </Select>
                            <Label id="_IDGenLabel5dp" text="Order" class="sapUiSmallMarginTop"/>
                            <SegmentedButton id="sortOrderBtndp" selectedKey="asc">
                                <items>
                                    <SegmentedButtonItem id="_IDGenSegmentedButtonItem2" key="asc"  text="Ascending"/>
                                    <SegmentedButtonItem id="_IDGenSegmentedButtonItem3" key="desc" text="Descending"/>
                                </items>
                            </SegmentedButton>
                        </VBox>
                    </IconTabFilter>

                    <IconTabFilter id="_IDGenIconTabFilter1dp" text="Filter" key="filter">
                        <VBox id="_IDGenVBox2dp" class="sapUiSmallMargin">
                            <Label id="_IDGenLabel6dp" text="Filter By"/>
                            <Select id="filterFieldSelectdp" change="onFilterFieldChange">
                                <items>
                                    <core:Item id="_IDGenItem39" key=""         text="Select Field"/>
                                    <core:Item id="_IDGenItem40" key="docNo"    text="Document Number"/>
                                    <core:Item id="_IDGenItem41" key="year1"    text="Fiscal Year"/>
                                    <core:Item id="_IDGenItem42" key="lineItem" text="Line Item"/>
                                    <core:Item id="_IDGenItem43" key="vendor"   text="Supplier"/>
                                    <core:Item id="_IDGenItem44" key="amntLC"   text="Amount (Local)"/>
                                    <core:Item id="_IDGenItem45" key="amntDC"   text="Amount (Doc)"/>
                                    <core:Item id="_IDGenItem46" key="curr"     text="Currency"/>
                                    <core:Item id="_IDGenItem47" key="refNo"    text="Reference"/>
                                    <core:Item id="_IDGenItem48" key="assignNo" text="Assignment"/>
                                    <core:Item id="_IDGenItem49" key="compCode" text="Company Code"/>
                                </items>
                            </Select>
                            <Label id="_IDGenLabel7dp" text="Operator" class="sapUiSmallMarginTop"/>
                            <Select id="filterOperatorSelectdp">
                                <items>
                                    <core:Item id="_IDGenItem50" key="Contains"   text="Contains"/>
                                    <core:Item id="_IDGenItem51" key="EQ"         text="Equals"/>
                                    <core:Item id="_IDGenItem52" key="StartsWith" text="Starts With"/>
                                    <core:Item id="_IDGenItem53" key="EndsWith"   text="Ends With"/>
                                </items>
                            </Select>
                            <Label id="_IDGenLabel8dp" text="Value" class="sapUiSmallMarginTop"/>
                            <Input      id="filterValueInputdp"  placeholder="Enter filter value..." width="100%"/>
                            <DatePicker id="filterDatePickerdp"  visible="false" width="100%" placeholder="Select date..." displayFormat="MM/dd/yyyy"/>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        <buttons>
            <Button id="_IDGenButton9" text="OK"     type="Emphasized" press="onViewSettingsConfirm"/>
            <Button id="_IDGenButton10" text="Reset"                    press="onViewSettingsReset"/>
            <Button id="_IDGenButton12" text="Cancel"                   press="onViewSettingsCancel"/>
        </buttons>
    </Dialog>

</core:FragmentDefinition>