<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="houseBankAccountVHdp"
        title="Select House Bank Account"
        search=".InputHelpsDP.onSearchHouseBankAccount"
        confirm=".InputHelpsDP.onConfirmHouseBankAccount"
        cancel=".InputHelpsDp.onCloseHouseBankAccountDialog"
        items="{/I_HouseBankAccountVH}">
        <StandardListItem id="_IDGenStandardListItem3dp"
            title="{HouseBankAccount}"
            description="{HouseBankAccountDescription}"
            info="{BankAccount}"
            type="Active"/>
    </SelectDialog>
    
</core:FragmentDefinition>