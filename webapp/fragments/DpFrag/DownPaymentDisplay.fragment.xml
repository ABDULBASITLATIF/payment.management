<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <f:SimpleForm id="dp_paymentFormDisplay"
        editable="false"
        title="Down Payment"
        layout="ColumnLayout"
        columnsM="2"
        columnsL="3"
        columnsXL="4">
        <f:content>

            <Label id="dp_draftidLabelD"      text="Draft ID"              width="auto"/>
            <Text  id="dp_draftidText"         text="{pageModel>/draftId}"  width="auto"/>

            <Label id="dp_companyCodeLabelD"   text="Company Code"          width="auto"/>
            <Text  id="dp_companyCodeText"     text="{pageModel>/compCode}" width="auto"/>

            <Label id="dp_fiscalYearLabelD"    text="Fiscal Year"           width="auto"/>
            <Text  id="dp_fiscalYearText"      text="{pageModel>/fiscYear}" width="auto"/>

            <Label id="dp_documentDateLabelD"  text="Document Date"         width="auto"/>
            <Text  id="dp_documentDateText"    text="{pageModel>/docDate}"  width="auto"/>

            <Label id="dp_postingDateLabelD"   text="Posting Date"          width="auto"/>
            <Text  id="dp_postingDateText"     text="{pageModel>/postingDate}" width="auto"/>

            <Label id="dp_referenceLabelD"     text="Reference"             width="auto"/>
            <Text  id="dp_referenceText"       text="{pageModel>/reference}" width="auto"/>

            <Label id="dp_headerTextLabelD"    text="Header Text"           width="auto"/>
            <Text  id="dp_headTextText"        text="{pageModel>/headText}" width="auto"/>

            <Label id="dp_houseBankLabelD"     text="House Bank"            width="auto"/>
            <Text  id="dp_houseBankText"       text="{pageModel>/bankKey}"  width="auto"/>

            <Label id="dp_houseBankAccLabelD"  text="House Bank Account ID" width="auto"/>
            <Text  id="dp_houseBankAccText"    text="{pageModel>/bankAcc}"  width="auto"/>

            <Label id="dp_glAccountLabelD"     text="G/L Account"           width="auto"/>
            <Text  id="dp_glAccountText"       text="{pageModel>/bankGL}"   width="auto"/>

            <Label id="dp_supplierLabelD"      text="Vendor"                width="auto"/>
            <Text  id="dp_supplierText"        text="{pageModel>/vendor}"   width="auto"/>

            <Label id="dp_currencyLabelD"      text="Currency"              width="auto"/>
            <Text  id="dp_currencyText"        text="{pageModel>/curr}"     width="auto"/>

            <Label id="dp_payAmountLabelD"     text="Total Pay. Amount"     width="auto"/>
            <Text  id="dp_payAmntText"         text="{pageModel>/payAmnt}"  width="auto"/>

            <Label id="dp_invoiceSumLabelD"    text="Total Invoice Sum"     width="auto"/>
            <Text  id="dp_invoiceSumText"      text="{pageModel>/invoiceSum}" width="auto"/>

            <Label id="dp_balanceLabelD"       text="Balance"               width="auto"/>
            <Text  id="dp_balanceText"         text="{pageModel>/balance}"  width="auto"/>

            <Label id="dp_postdoclabel"        text="Posting Document"      width="auto" visible="false"/>
            <Text  id="dp_postdocText"         text="{pageModel>/postDoc}"  width="auto" visible="false"/>

            <Label id="dp_postmsglabel"        text="Posting Message"       width="auto" visible="false"/>
            <TextArea id="dp_postmsgText"      value="{pageModel>/msg}"     width="auto" visible="false" editable="false"/>

        </f:content>
    </f:SimpleForm>

</core:FragmentDefinition>