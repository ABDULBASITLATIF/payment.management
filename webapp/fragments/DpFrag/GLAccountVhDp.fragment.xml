<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="glAccountVHdp"
        title="Select G/L Account"
        search=".InputHelpsDP.onSearchGLAccount"
        confirm=".InputHelpsDP.onConfirmGLAccount"
        cancel=".InputHelpsDP.onCloseGLAccountDialog"
        items="{/bankGLS}">
        <StandardListItem id="_IDGenStandardListItem4dp"
            title="{GLAccount}"
            description="{glDesc}"
            info="Company: {CompanyCode}, Bank: {HouseBank}"
            type="Active"/>
    </SelectDialog>
    
</core:FragmentDefinition>