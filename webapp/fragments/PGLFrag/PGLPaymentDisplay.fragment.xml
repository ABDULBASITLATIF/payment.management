<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <f:SimpleForm id="pgl_paymentFormDisplay"
        editable="false"
        title=" Gl Payment"
        layout="ColumnLayout"
        columnsM="2"
        columnsL="3"
        columnsXL="4">
        <f:content>

            <Label id="pgl_draftidLabelD"      text="Draft ID"              width="auto"/>
            <Text  id="pgl_draftidText"         text="{pageModel>/draftId}"  width="auto"/>

            <Label id="pgl_companyCodeLabelD"   text="Company Code"          width="auto"/>
            <Text  id="pgl_companyCodeText"     text="{pageModel>/compCode}" width="auto"/>

            <Label id="pgl_fiscalYearLabelD"    text="Fiscal Year"           width="auto"/>
            <Text  id="pgl_fiscalYearText"      text="{pageModel>/fiscYear}" width="auto"/>

            <Label id="pgl_documentDateLabelD"  text="Document Date"         width="auto"/>
            <Text  id="pgl_documentDateText"    text="{pageModel>/docDate}"  width="auto"/>

            <Label id="pgl_postingDateLabelD"   text="Posting Date"          width="auto"/>
            <Text  id="pgl_postingDateText"     text="{pageModel>/postingDate}" width="auto"/>

            <Label id="pgl_referenceLabelD"     text="Reference"             width="auto"/>
            <Text  id="pgl_referenceText"       text="{pageModel>/reference}" width="auto"/>

            <Label id="pgl_headerTextLabelD"    text="Header Text"           width="auto"/>
            <Text  id="pgl_headTextText"        text="{pageModel>/headText}" width="auto"/>

            <Label id="pgl_houseBankLabelD"     text="House Bank"            width="auto"/>
            <Text  id="pgl_houseBankText"       text="{pageModel>/bankKey}"  width="auto"/>

            <Label id="pgl_houseBankAccLabelD"  text="House Bank Account ID" width="auto"/>
            <Text  id="pgl_houseBankAccText"    text="{pageModel>/bankAcc}"  width="auto"/>

            <Label id="pgl_glAccountLabelD"     text="G/L Account"           width="auto"/>
            <Text  id="pgl_glAccountText"       text="{pageModel>/bankGL}"   width="auto"/>
 

            <Label id="pgl_currencyLabelD"      text="Currency"              width="auto"/>
            <Text  id="pgl_currencyText"        text="{pageModel>/curr}"     width="auto"/>

            <Label id="pgl_payAmountLabelD"     text="Total Pay. Amount"     width="auto"/>
            <Text  id="pgl_payAmntText"         text="{pageModel>/payAmnt}"  width="auto"/>

            <Label id="pgl_invoiceSumLabelD"    text="Total Invoice Sum"     width="auto" visible="false"/>
            <Text  id="pgl_invoiceSumText"      text="{pageModel>/invoiceSum}" width="auto" visible="false"/>

            <Label id="pgl_balanceLabelD"       text="Balance"               width="auto" visible="false"/>
            <Text  id="pgl_balanceText"         text="{pageModel>/balance}"  width="auto" visible="false"/>

            <Label id="pgl_postdoclabel"        text="Posting Document"      width="auto" visible="false"/>
            <Text  id="pgl_postdocText"         text="{pageModel>/postDoc}"  width="auto" visible="false"/>

            <Label id="pgl_postmsglabel"        text="Posting Message"       width="auto" visible="false"/>
            <TextArea id="pgl_postmsgText"      value="{pageModel>/msg}"     width="auto" visible="false" editable="false"/>

            <Label id="pgl_totalDebitLabelD"  text="Total Debit"  width="auto"/>
            <Text  id="pgl_totalDebitText"    text="{pageModel>/totalDebit}"  width="auto"/>

            <Label id="pgl_totalCreditLabelD" text="Total Credit" width="auto"/>
            <Text  id="pgl_totalCreditText"   text="{pageModel>/totalCredit}" width="auto"/>

            <Label id="pgl_lineBalanceLabelD" text="Balance"      width="auto"/>
            <Text  id="pgl_lineBalanceText"   text="{pageModel>/lineBalance}" width="auto"/>

        </f:content>
    </f:SimpleForm>

</core:FragmentDefinition>