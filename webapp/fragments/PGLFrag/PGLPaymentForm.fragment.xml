<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <f:SimpleForm id="pgl_paymentForm"
        editable="true"
        title="Post To GL Account"
        layout="ColumnLayout"
        columnsM="2"
        columnsL="3"
        columnsXL="4">
        <f:content>
            <Label id="pgl_draftidLabel" text="Draft ID" required="true" width="auto"/>
            <Input id="pgl_draftidInput" value="{glData>/values/draftID}" editable="false" width="auto"
                    valueState="{glData>/state/draftID}" />
            
            <Label id="pgl_companyCodeLabel" text="Company Code" required="true" width="auto"/>
            <Input id="pgl_companyCodeInput" value="{glData>/values/compCode}" maxLength="4" width="auto" showValueHelp="true" 
            valueHelpRequest=".InputHelpsPGL.onLoadCCVH" valueState="{glData>/state/compCode}"
                    submit=".FieldValidations.validCompCode"/>
            
            <Label id="pgl_documentDateLabel" text="Document Date" required="true" width="auto"/>
            <DatePicker id="pgl_documentDatePicker" 
                value="{path : 'glData>/values/docDate' , type: 'sap.ui.model.type.Date'}"
                valueFormat="dd/MM/yyyy"  
                displayFormat="dd/MM/yyyy"
                width="auto"/>
            
            <Label id="pgl_postingDateLabel" text="Posting Date" required="true" width="auto"/>
            <DatePicker id="pgl_postingDatePicker" 
                value="{path : 'glData>/values/postDate', type: 'sap.ui.model.type.Date'}"
                valueFormat="yyyy/MM/dd"   
                displayFormat="dd/MM/yyyy"
                width="auto"/>
            
            <Label id="pgl_referenceLabel" text="Reference" width="auto"/>
            <Input id="pgl_referenceInput" value="{glData>/values/refer}" maxLength="16" width="auto"/>
            
            <Label id="pgl_headerTextLabel" text="Header Text" width="auto"/>
            <Input id="pgl_headerTextInput" value="{glData>/values/headText}" maxLength="25" width="auto"/>
            
            <Label id="pgl_houseBankLabel" text="House Bank" required="true" width="auto"/>
            <Input id="pgl_houseBankInput" value="{glData>/values/bankID}" maxLength="5" width="auto" 
                    showValueHelp="true" valueHelpRequest=".InputHelpsPGL.onLoadHouseBankVH" 
                    submit=".FieldValidations.validBankID" change=".FieldValidations.validBankID"
                    valueState="{glData>/state/bankID}"/>
            
            <Label id="pgl_houseBankAccountLabel" text="House Bank Account ID" required="true" width="auto"/>
            <Input id="pgl_houseBankAccountInput" value="{glData>/values/bankAcc}" maxLength="5" width="auto" 
                    showValueHelp="true" valueHelpRequest=".InputHelpsPGL.onLoadHouseBankAccountVH"
                    valueState="{glData>/state/bankAcc}"
                    submit=".FieldValidations.validBnkAcc" change=".FieldValidations.validBnkAcc"/>
        
            <Label id="pgl_glAccountLabel" text="G/L Account" required="true" width="auto"/>
            <Input id="pgl_glAccountInput" value="{glData>/values/bankGL}" maxLength="10" width="auto"
                    showValueHelp="true" valueHelpRequest=".InputHelpsPGL.onLoadGLVH"
                    valueState="{glData>/state/bankGL}" 
                    submit=".FieldValidations.validBankGL" change=".FieldValidations.validBankGL"/>            
         
            
            <Label id="pgl_currencyLabel" text="Currency" required="true" width="auto"/>
            <Input id="pgl_currencyInput" value="{glData>/values/curr}" 
                    maxLength="5" width="auto" valueState="{glData>/state/curr}"
                    />
            
            <Label id="pgl_payAmountLabel" text="Total Pay. Amount" width="auto"/>
            <Input id="pgl_payAmountInput" value="{glData>/values/payAmnt}" width="auto" change="onPayAmountChange" submit="calcBalance"/>

            <Label id="pgl_invoiceSumLabel" text="Total Invoice Sum" width="auto" visible="false"/>
            <Input id="pgl_invoiceSumInput" value="{glData>/values/}" width="auto" editable="false" visible="false"/>

            <Label id="pgl_balanceLabel" text="Balance" width="auto" visible="false"/>
            <Input id="pgl_balanceInput" value="{glData>/values/balance}" width="auto" 
                    editable="false" visible="false" valueState="{glData>/state/balance}"/>
            
            <Label id="pgl_totalDebitLabel" text="Total Debit" width="auto"/>
            <Input id="pgl_totalDebitInput" value="{glData>/values/debit}" width="auto" editable="false"/>

            <Label id="pgl_totalCreditLabel" text="Total Credit" width="auto"/>
            <Input id="pgl_totalCreditInput" value="{glData>/values/credit}" width="auto" editable="false"/>

            <Label id="pgl_lineBalanceLabel" text="Balance" width="auto"/>
            <Input id="pgl_lineBalanceInput" value="{glData>/values/balance}" width="auto" editable="false"/>
        </f:content>
    </f:SimpleForm>
    
</core:FragmentDefinition>