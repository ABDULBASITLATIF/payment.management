<mvc:View
    controllerName="zfi.payment.management.controller.PostGL"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    height="100%">

    <Page id="postglpage"
        title="Post To GL Account"
        showNavButton="true"
        navButtonPress="onNavBack">

        <customHeader>
            <Bar id="_IDGenBar4">
                <contentLeft>
                    <Button id="_IDGenButtongl" icon="sap-icon://nav-back" press="onNavBack"/>
                </contentLeft>
                <contentMiddle>
                    <Title id="downpaymentgl" text="Post To GL Account"/>
                </contentMiddle>
            </Bar>
        </customHeader>

        <content>
            <VBox id="_IDGenVBox22gl" class="sapUiSmallMargin">

                <!-- Edit Form -->
                <VBox id="gl_editFormBox">
                    <core:Fragment
                        fragmentName="zfi.payment.management.fragments.PGLFrag.PGLPaymentForm"
                        type="XML"/>
                </VBox>

                <!-- Display Form (In Approval / Approved / Posted / Post Error) -->
                <VBox id="gl_displayFormBox" visible="false">
                    <core:Fragment
                        fragmentName="zfi.payment.management.fragments.PGLFrag.PGLPaymentDisplay"
                        type="XML"/>
                </VBox>


                <VBox id="_IDGenVBox4" >
                    <f:SimpleForm id="pglitemform"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    width="auto"
                    columnsXL="1"
                    columnsL="1"
                    columnsM="1"
                    class="sapUiSmallMarginTop">
                    <f:content>
                        <Table
                            id="pglitemtable"
                            items="{path: 'lineItems>/items'}"
                            mode="SingleSelectMaster"
                            selectionChange="onLineItemSelectionChange"
                            width="auto"
                            fixedLayout="Strict"
                            autoPopinMode="true"
                            sticky="ColumnHeaders,HeaderToolbar">

                            <headerToolbar>
                                <OverflowToolbar id="pglItemsToolbar">
                                    <Title id="pglItemsTitle" text="GL Line Items" level="H5"/>
                                    <ToolbarSpacer id="pgl_openItemsSpacer"/>
                                    <Button id="pglItemsInfoBtn"  icon="sap-icon://add"  text="Add"  press="onOpenLineItemDialog" type="Emphasized"
                                            visible="{glData>/visAddR}"/>
                                    <Button id="pglItemsInfoedit" icon="sap-icon://edit" text="Edit" press="onEditLineItem" enabled="false"
                                            visible="{glData>/visEditR}"/>
                                    <Button id="pglItemsInfodelete" icon="sap-icon://delete" text="Delete" press="onDeleteLineItem" enabled="false"   visible="{glData>/visAddR}"/>        
                                </OverflowToolbar>
                            </headerToolbar>

                           <columns>
                                <Column id="glacc"        width="auto"><header><Text id="_IDGenText53" text="GL Account"/></header></Column>
                                <Column id="amount"       width="auto"><header><Text id="_IDGenText61" text="Amount"/></header></Column>
                                <Column id="textcode"     width="auto"><header><Text id="_IDGenText62" text="Tax Code"/></header></Column>
                                <Column id="debitCol"     width="auto"><header><Text id="_IDGenText63" text="Debit/Credit Ind."/></header></Column>
                                <Column id="taxamountCol" width="auto"><header><Text id="_IDGenText64" text="Tax Amount"/></header></Column>
                                <Column id="amtwithtax"   width="auto"><header><Text id="_IDGenText65" text="Amount With Tax"/></header></Column>
                                <Column id="costcentr"    width="auto"><header><Text id="_IDGenText66" text="Cost Center"/></header></Column>
                                <Column id="profitcentr"  width="auto"><header><Text id="_IDGenText67" text="Profit Center"/></header></Column>
                                <Column id="wbselement"   width="auto"><header><Text id="_IDGenText68" text="WBS Element"/></header></Column>
                                <Column id="itemtext"     width="auto"><header><Text id="_IDGenText69" text="Item Text"/></header></Column>
                            </columns>

                            <items>
                                <ColumnListItem id="pgllistitem">
                                    <cells>
                                        <Text id="_IDGenText70" text="{lineItems>glAccount}"/>
                                        <Text id="_IDGenText71" text="{lineItems>amount}"/>
                                        <Text id="_IDGenText72" text="{lineItems>taxCode}"/>
                                        <Text id="_IDGenText73" text="{
                                            path: 'lineItems>dcIndicator',
                                            formatter: '.formatDCIndicator'
                                        }"/>
                                        <Text id="_IDGenText74" text="{lineItems>taxAmount}"/>
                                        <Text id="_IDGenText75" text="{lineItems>amountWithTax}"/>
                                        <Text id="_IDGenText76" text="{lineItems>costCenter}"/>
                                        <Text id="_IDGenText77" text="{lineItems>profitCenter}"/>
                                        <Text id="_IDGenText78" text="{lineItems>wbs}"/>
                                        <Text id="_IDGenText79" text="{lineItems>itemText}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                                                    </Table>
                    </f:content>
                </f:SimpleForm>
                
                </VBox>

                <!-- Approver Table -->
                <Table
                    id="gl_aprvrTable"
                    visible="false"
                    items="{path: 'aprvrTab>/'}"
                    width="100%"
                    growing="true"
                    growingThreshold="100"
                    growingScrollToLoad="true"
                    class="sapUiSmallMarginTop">

                    <headerToolbar>
                        <OverflowToolbar id="gl_aprvrTabTool">
                            <Title id="gl_aprvrTabTitle" text="Approver Table" level="H5"/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column id="gl_levelCol" width="4rem">
                            <Text id="gl_levelCT" text="Approver Level"/>
                        </Column>
                        <Column id="gl_UserCol" width="7rem">
                            <Text id="gl_UserCT" text="User Name"/>
                        </Column>
                        <Column id="gl_StatusCol" width="5rem">
                            <Text id="gl_StatusCT" text="Status"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem id="gl_aprvColItem">
                            <cells>
                                <Text id="gl_levelCell"  text="{aprvrTab>aprLevel}"/>
                                <Text id="gl_userCell"   text="{aprvrTab>aprvr}"/>
                                <Text id="gl_statusCell" text="{aprvrTab>aprvrStatus}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>

 

        </content>

        <footer>
            <Toolbar id="_IDGenToolbargl">
                <ToolbarSpacer id="_IDGenToolbarSpacergl"/>
                <Button id="_IDGenButton25gl"  text="Save"      type="Emphasized" press="onSave" visible="{glData>visSave}"/>
                <Button id="_IDGenButton27gl"  text="Update"    type="Emphasized" press="onUpdate" visible="{glData>visUpd}"/>
                <Button id="_IDGenButton26gl"  text="Submit"    type="Emphasized" press="onSubmit" visible="{glData>visSub}"/>
                <Button id="_IDGenButton2622gl" text="Post"     type="Emphasized" press="onPost"      visible="false"/>
                <Button id="resubmitButtongl"  text="Resubmit" type="Emphasized" press="onResubmit"  visible="false"/>
            </Toolbar>
        </footer>

    </Page>
</mvc:View>



